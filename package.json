{
  "name": "nuxt-graphql-server",
  "version": "3.1.6",
  "description": "Easy GraphQL server implementation with Nuxt",
  "license": "MIT",
  "repository": "https://github.com/tobiasdiez/nuxt-graphql-server",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "scripts": {
    "prepack": "nuxi prepare playground && nuxt-module-build build",
    "build": "pnpm prepack",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "lint": "pnpm lint:eslint && pnpm lint:oxfmt",
    "lint:eslint": "eslint --report-unused-disable-directives .",
    "lint:oxfmt": "oxfmt --check",
    "release": "standard-version && git push --follow-tags && pnpm publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@graphql-codegen/core": "^5.0.0",
    "@graphql-codegen/plugin-helpers": "^6.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.0.0",
    "@graphql-tools/graphql-file-loader": "^8.0.19",
    "@graphql-tools/load": "^8.0.19",
    "@nuxt/devtools-kit": "^3.2.2",
    "@nuxt/kit": "^4.0.0",
    "defu": "^6.1.4",
    "multimatch": "^8.0.0"
  },
  "devDependencies": {
    "@apollo/server": "5.5.0",
    "@as-integrations/h3": "2.0.3",
    "@nuxt/devtools": "3.2.4",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.2",
    "@nuxt/test-utils": "3.21.0",
    "@vitest/coverage-v8": "4.1.5",
    "commit-and-tag-version": "12.7.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-unjs": "0.6.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "graphql": "16.13.2",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "6.0.8",
    "nuxt": "4.4.2",
    "oxfmt": "0.47.0",
    "shx": "0.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  },
  "peerDependencies": {
    "graphql": "^16.7.1"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}
